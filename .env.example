# Supabase – nach Erstellung eines neuen Projekts eintragen
# Siehe SUPABASE_SETUP.md für die Anleitung

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
VITE_SUPABASE_PROJECT_ID=your_project_ref

# Zugangsschutz: Vollbild-Passwort vor der App (wird beim Build in index.html eingetragen).
# Lokal: .env wie hier. Für Vercel o. Ä.: gleicher Name unter Project → Settings → Environment Variables (Production), dann neu deployen — nur .env auf dem Laptop reicht für die Live-URL nicht.
VITE_APP_ACCESS_PASSWORD=KIAbrechnung2026!

# Optional: Nach dem Gate automatisch bei Supabase anmelden (Chat/DB wie zuvor).
# VITE_AUTO_LOGIN_EMAIL=
# VITE_AUTO_LOGIN_PASSWORD=

# Optional: Observability (Cycle 01 — Spec §2.3 / §2.4)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.posthog.com
# VITE_SENTRY_DSN=

# Optional: Sandbox „Neue Dokumentation“ — Straßen-Adressvorschläge (Google Places API)
# VITE_GOOGLE_MAPS_API_KEY=

# Edge Function Secret (im Supabase Dashboard setzen, nicht hier):
# OPENROUTER_API_KEY=sk-or-v1-...
